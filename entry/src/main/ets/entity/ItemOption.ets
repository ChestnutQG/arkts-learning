/**
 * =============================================================================
 *  ItemOption 接口 - 列表项选项的数据格式定义
 * =============================================================================
 * 【作用】
 *   定义通用列表项的数据结构，包含名称(name)、图标(icon?) 和描述(desc?) 三个字段。
 *   用于 WaterFlowDataSource 中表示每条星球数据的形状。
 *
 * 【接口 vs 类】
 *   接口（interface）只定义"形状"不包含实现，比类更轻量。
 *   这里用接口是因为我们只需要"数据容器"的类型约束，不需要方法逻辑。
 *
 * 【可选字段】
 *   icon 和 desc 用 ? 标记为可选参数，创建对象时可以只传 name。
 * =============================================================================
 */

/**
 * 列表项选项接口
 * 描述一个可展示的选项条目，包含必填的名称和可选的图标、描述
 */
export interface ItemOption {
  /** 选项名称（必填字段），如 "水星"、"金星"、"火星" 等星球名称 */
  name: string;

  /**
   * 选项图标资源引用（可选字段）
   * 类型为 Resource，对应 $r('app.media.xxx') 的编译期资源引用
   * 可选意味着某些条目可以没有图标
   */
  icon?: Resource;

  /**
   * 选项描述信息（可选字段）
   * 如 "水星是太阳系八大行星最内侧也是最小的一颗行星"
   */
  desc?: string;
}
